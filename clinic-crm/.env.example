# ─────────────────────────────────────────────────────────────────────────────
# .env.example
#
# Copy this file to .env.local for local development, then fill in real values.
#   cp .env.example .env.local
#
# NEVER commit .env.local or any file containing real secrets.
# This file (.env.example) is safe to commit — it contains only placeholder
# values and documentation.
#
# Production: set all variables marked [REQUIRED] in Vercel Dashboard →
# Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] Neon (or any PostgreSQL) connection string.
# Get it from: https://console.neon.tech → your project → Connection Details
# The ?sslmode=require suffix is mandatory for Neon.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"


# ── NextAuth ──────────────────────────────────────────────────────────────────
# [REQUIRED] Random secret used to sign JWT session tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-string"

# [REQUIRED] The canonical URL of your deployment.
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app  (or your custom domain)
NEXTAUTH_URL="http://localhost:3000"


# ── Email (Resend) ────────────────────────────────────────────────────────────
# [REQUIRED] Resend API key for transactional email.
# Get it from: https://resend.com/api-keys
# Test key format (no real sends): re_test_...
RESEND_API_KEY="re_..."

# [REQUIRED] The "from" address for all outbound emails.
# Must be a verified domain in your Resend account.
EMAIL_FROM="noreply@yourdomain.com"


# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# [REQUIRED] Permanent access token from Meta for Developers.
# Get it from: https://developers.facebook.com → your app → WhatsApp → API Setup
META_WA_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxx"

# [REQUIRED] The phone number ID (not the phone number itself).
# Found in: Meta for Developers → your app → WhatsApp → API Setup → Phone number ID
META_WA_PHONE_ID="1234567890"

# [REQUIRED in production] Approved WhatsApp template names for each notification type.
# Templates must be approved by Meta before they can be used.
# Create templates at: https://business.facebook.com/wa/manage/message-templates
META_WA_TEMPLATE_BOOKING="booking_confirmation"
META_WA_TEMPLATE_REMINDER="appointment_reminder"
META_WA_TEMPLATE_MISSED="missed_appointment"


# ── Upstash Redis ─────────────────────────────────────────────────────────────
# [REQUIRED] Upstash Redis REST API credentials for:
#   - Distributed rate limiting (all API routes)
#   - Session revocation denylist (force-logout)
# Get them from: https://console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ── Cron jobs ─────────────────────────────────────────────────────────────────
# [REQUIRED] Secret token that authorises calls to /api/cron/* endpoints.
# Must be set identically in:
#   - Vercel Dashboard → Environment Variables       (for Vercel cron)
#   - GitHub Actions secrets as CRON_SECRET          (for the hourly reminder workflow)
# Generate one with: openssl rand -hex 32
CRON_SECRET="replace-with-a-random-hex-string"


# ── Sentry ────────────────────────────────────────────────────────────────────
# [REQUIRED in production] Sentry DSN for server-side error tracking.
# Get it from: https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX"

# [REQUIRED in production] Client-side Sentry DSN (safe to expose to the browser).
# Usually the same value as SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX"


# ── Public app URL ────────────────────────────────────────────────────────────
# [REQUIRED in production] The public-facing URL of the app.
# Used for: CSP connect-src header, absolute URLs in emails.
# Local dev: leave blank or set to http://localhost:3000
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"


# ── Development overrides ─────────────────────────────────────────────────────
# [OPTIONAL] Override the destination for all outbound emails/SMS in dev so
# you never accidentally send to real patients during local testing.
DEV_TEST_EMAIL="your-personal-email@example.com"
DEV_TEST_PHONE="+919999999999"
