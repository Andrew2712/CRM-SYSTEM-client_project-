//
// prisma/schema.prisma
//
// ─── WHAT CHANGED ────────────────────────────────────────────────────────────
//
// Added to the Appointment model:
//
//   @@index([doctorId, startTime, endTime])
//
// Why not @@unique([doctorId, startTime])?
// ─────────────────────────────────────────
// A unique constraint on (doctorId, startTime) would only block exact
// duplicate start times. It would NOT catch overlapping sessions with different
// start times (e.g. 10:00–11:00 vs 10:30–11:30). The overlap is enforced at
// the application layer inside the Serializable transaction; the composite
// index just makes that overlap query fast.
//
// The index covers:
//   WHERE doctorId = $1
//     AND startTime < $newEnd      ← range scan on startTime
//     AND endTime   > $newStart    ← covered by the index
//     AND status IN (...)
//
// Additionally added @@index([doctorId, status]) to speed up availability
// lookups that filter by doctor + status.
//
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                      @id @default(cuid())
  name                  String
  email                 String                      @unique
  passwordHash          String
  role                  Role                        @default(RECEPTIONIST)
  phone                 String?
  createdAt             DateTime                    @default(now())

  // ── Soft delete ──────────────────────────────────────────
  isActive              Boolean                     @default(true)
  deletedAt             DateTime?
  // ─────────────────────────────────────────────────────────

  appointments          Appointment[]               @relation("DoctorAppointments")
  auditLogs             AuditLog[]
  availability          AvailabilitySlot[]
  inAppNotifications    InAppNotification[]
  holidayRequests       HolidayRequest[]            @relation("DoctorHolidayRequests")
  reassignmentRequests  DoctorReassignmentRequest[] @relation("ReassignmentRequester")
  reassignmentsFrom     DoctorReassignmentRequest[] @relation("ReassignmentFrom")
  reassignmentsTo       DoctorReassignmentRequest[] @relation("ReassignmentTo")
  expenses              Expense[]
}

model Patient {
  id                   String         @id @default(cuid())
  patientCode          String         @unique
  name                 String
  phone                String         @unique
  email                String?
  dob                  DateTime?
  address              String?
  status               PatientStatus  @default(NEW)
  createdAt            DateTime       @default(now())
  age                  Int?
  gender               Gender?
  medicalConditions    String?
  phase                Phase?
  purposeOfVisit       String?
  totalSessionsPlanned Int            @default(0)
  passwordHash         String?

  // ── Soft delete ──────────────────────────────────────────
  isActive             Boolean        @default(true)
  deletedAt            DateTime?
  // ─────────────────────────────────────────────────────────

  appointments         Appointment[]
  visits               PatientVisit[]
}

model Appointment {
  id                   String                      @id @default(cuid())
  patientId            String
  doctorId             String
  startTime            DateTime
  endTime              DateTime
  status               AppointmentStatus           @default(CONFIRMED)
  sessionType          SessionType
  rescheduleCount      Int                         @default(0)
  createdAt            DateTime                    @default(now())
  doctor               User                        @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient              Patient                     @relation(fields: [patientId], references: [id])
  notifications        Notification[]
  visit                PatientVisit?
  notes                String?
  reassignmentRequests DoctorReassignmentRequest[]

  // ── Booking-conflict indexes ──────────────────────────────────────────────
  // Composite index on (doctorId, startTime, endTime) makes the overlap query
  // in findOverlappingAppointment() an efficient index range scan rather than
  // a sequential table scan.
  @@index([doctorId, startTime, endTime])
  // Quick lookup by doctor + status for availability checks
  @@index([doctorId, status])
  // ─────────────────────────────────────────────────────────────────────────
}

model PatientVisit {
  id            String            @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String            @unique
  sessionType   SessionType
  notes         String?
  status        AppointmentStatus
  visitDate     DateTime
  appointment   Appointment       @relation(fields: [appointmentId], references: [id])
  patient       Patient           @relation(fields: [patientId], references: [id])
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  doctorId  String
  slotDate  DateTime
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  doctor    User     @relation(fields: [doctorId], references: [id])
}

model Notification {
  id            String              @id @default(cuid())
  appointmentId String
  channel       NotificationChannel
  scheduledAt   DateTime
  sentAt        DateTime?
  status        NotificationStatus  @default(PENDING)
  appointment   Appointment         @relation(fields: [appointmentId], references: [id])
}

model InAppNotification {
  id        String         @id @default(cuid())
  userId    String
  type      InAppNotifType
  title     String
  body      String
  read      Boolean        @default(false)
  entityId  String?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
}

model HolidayRequest {
  id        String               @id @default(cuid())
  doctorId  String
  date      DateTime
  reason    String
  status    HolidayRequestStatus @default(PENDING)
  createdAt DateTime             @default(now())
  doctor    User                 @relation("DoctorHolidayRequests", fields: [doctorId], references: [id])
}

model DoctorReassignmentRequest {
  id                String             @id @default(cuid())
  appointmentId     String
  requestedByUserId String
  fromDoctorId      String
  toDoctorId        String
  status            ReassignmentStatus @default(PENDING)
  notes             String?
  createdAt         DateTime           @default(now())
  appointment       Appointment        @relation(fields: [appointmentId], references: [id])
  requestedBy       User               @relation("ReassignmentRequester", fields: [requestedByUserId], references: [id])
  fromDoctor        User               @relation("ReassignmentFrom", fields: [fromDoctorId], references: [id])
  toDoctor          User               @relation("ReassignmentTo", fields: [toDoctorId], references: [id])
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Phase {
  PHASE_1
  PHASE_2
  PHASE_3
  PHASE_4
  PHASE_5
}

enum PatientStatus {
  NEW
  RETURNING
}

enum AppointmentStatus {
  CONFIRMED
  ATTENDED
  MISSED
  CANCELLED
  RESCHEDULED
}

enum SessionType {
  INITIAL_ASSESSMENT
  FOLLOW_UP
  SPECIALIZED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  CALENDAR
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum InAppNotifType {
  APPOINTMENT_CREATED
  APPOINTMENT_MISSED
  SESSION_COMPLETED
  SYSTEM
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  DOCTOR_REASSIGNED
  HOLIDAY_REQUEST
  REASSIGNMENT_REQUEST
}

enum HolidayRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReassignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Expense Tracker ──────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  title       String
  description String?
  category    ExpenseCategory
  amount      Float
  expenseDate DateTime
  paymentMode PaymentMode
  isDeleted   Boolean         @default(false)
  deletedAt   DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy   User @relation(fields: [createdById], references: [id])
}

enum ExpenseCategory {
  SALARY
  RENT
  ELECTRICITY
  INTERNET
  EQUIPMENT
  MEDICINE
  MAINTENANCE
  MARKETING
  TRANSPORT
  OTHER
}

enum PaymentMode {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(cuid())
  userId      String
  userName    String
  userRole    String
  action      AuditAction
  entity      String
  entityId    String
  description String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  PASSWORD_RESET
  ROLE_CHANGE
}
