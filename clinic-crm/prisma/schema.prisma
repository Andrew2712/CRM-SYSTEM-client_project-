generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                      @id @default(cuid())
  name                  String
  email                 String                      @unique
  passwordHash          String
  role                  Role                        @default(RECEPTIONIST)
  phone                 String?
  createdAt             DateTime                    @default(now())
  appointments          Appointment[]               @relation("DoctorAppointments")
  auditLogs             AuditLog[]
  availability          AvailabilitySlot[]
  inAppNotifications    InAppNotification[]
  holidayRequests       HolidayRequest[]            @relation("DoctorHolidayRequests")
  reassignmentRequests  DoctorReassignmentRequest[] @relation("ReassignmentRequester")
  reassignmentsFrom     DoctorReassignmentRequest[] @relation("ReassignmentFrom")
  reassignmentsTo       DoctorReassignmentRequest[] @relation("ReassignmentTo")
}

model Patient {
  id                   String         @id @default(cuid())
  patientCode          String         @unique
  name                 String
  phone                String         @unique
  email                String?
  dob                  DateTime?
  address              String?
  status               PatientStatus  @default(NEW)
  createdAt            DateTime       @default(now())
  age                  Int?
  gender               Gender?
  medicalConditions    String?
  phase                Phase?
  purposeOfVisit       String?
  totalSessionsPlanned Int            @default(0)
  passwordHash         String?
  appointments         Appointment[]
  visits               PatientVisit[]
}

model Appointment {
  id                   String                      @id @default(cuid())
  patientId            String
  doctorId             String
  startTime            DateTime
  endTime              DateTime
  status               AppointmentStatus           @default(CONFIRMED)
  sessionType          SessionType
  rescheduleCount      Int                         @default(0)
  createdAt            DateTime                    @default(now())
  doctor               User                        @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient              Patient                     @relation(fields: [patientId], references: [id])
  notifications        Notification[]
  visit                PatientVisit?
  notes                String?
  reassignmentRequests DoctorReassignmentRequest[]
}

model PatientVisit {
  id            String            @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String            @unique
  sessionType   SessionType
  notes         String?
  status        AppointmentStatus
  visitDate     DateTime
  appointment   Appointment       @relation(fields: [appointmentId], references: [id])
  patient       Patient           @relation(fields: [patientId], references: [id])
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  doctorId  String
  slotDate  DateTime
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)
  doctor    User     @relation(fields: [doctorId], references: [id])
}

model Notification {
  id            String              @id @default(cuid())
  appointmentId String
  channel       NotificationChannel
  scheduledAt   DateTime
  sentAt        DateTime?
  status        NotificationStatus  @default(PENDING)
  appointment   Appointment         @relation(fields: [appointmentId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id])
}

model InAppNotification {
  id        String         @id @default(cuid())
  userId    String
  type      InAppNotifType
  title     String
  body      String
  read      Boolean        @default(false)
  entityId  String?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
}

model HolidayRequest {
  id        String               @id @default(cuid())
  doctorId  String
  date      DateTime
  reason    String
  status    HolidayRequestStatus @default(PENDING)
  createdAt DateTime             @default(now())
  doctor    User                 @relation("DoctorHolidayRequests", fields: [doctorId], references: [id])
}

model DoctorReassignmentRequest {
  id                String             @id @default(cuid())
  appointmentId     String
  requestedByUserId String
  fromDoctorId      String
  toDoctorId        String
  status            ReassignmentStatus @default(PENDING)
  notes             String?
  createdAt         DateTime           @default(now())
  appointment       Appointment        @relation(fields: [appointmentId], references: [id])
  requestedBy       User               @relation("ReassignmentRequester", fields: [requestedByUserId], references: [id])
  fromDoctor        User               @relation("ReassignmentFrom", fields: [fromDoctorId], references: [id])
  toDoctor          User               @relation("ReassignmentTo", fields: [toDoctorId], references: [id])
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Phase {
  PHASE_1
  PHASE_2
  PHASE_3
  PHASE_4
  PHASE_5
}

enum PatientStatus {
  NEW
  RETURNING
}

enum AppointmentStatus {
  CONFIRMED
  ATTENDED
  MISSED
  CANCELLED
  RESCHEDULED
}

enum SessionType {
  INITIAL_ASSESSMENT
  FOLLOW_UP
  SPECIALIZED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  CALENDAR
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum InAppNotifType {
  APPOINTMENT_CREATED
  APPOINTMENT_MISSED
  SESSION_COMPLETED
  SYSTEM
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  DOCTOR_REASSIGNED
  HOLIDAY_REQUEST
  REASSIGNMENT_REQUEST
}

enum HolidayRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReassignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
}
